# ── Auth Provider ──
# "cognito" or "oidc"
AUTH_PROVIDER=cognito

# ── Cognito (when AUTH_PROVIDER=cognito) ──
COGNITO_POOL_ID=
COGNITO_CLIENT_ID=
COGNITO_DOMAIN=
COGNITO_REGION=us-east-1

# ── Generic OIDC (when AUTH_PROVIDER=oidc) ──
# Works with Auth0, Okta, Keycloak, etc.
OIDC_AUTHORITY=
OIDC_CLIENT_ID=
OIDC_REDIRECT_URI=
OIDC_POST_LOGOUT_REDIRECT_URI=

# ── App ──
API_BASE_URL=/api
APP_TITLE=Admin Mission Control

# ── Docker / Nginx ──
API_UPSTREAM=http://host.docker.internal:3001

# ── Vite local dev fallbacks (prefixed VITE_) ──
VITE_COGNITO_POOL_ID=
VITE_COGNITO_CLIENT_ID=
VITE_COGNITO_DOMAIN=
